      "source": [
        "from pyspark.sql import SparkSession\n",
        "\n",
        "spark = SparkSession.builder.appName(\"RDD Example\").getOrCreate()\n",
        "\n",
        "# Create RDD\n",
        "rdd = spark.sparkContext.parallelize([1, 2, 3, 4, 5])\n",
        "\n",
        "# Transformation\n",
        "rdd2 = rdd.map(lambda x: x * 2)\n",
        "\n",
        "# Action\n",
        "print(rdd2.collect())"
      ]
