      "source": [
        "from pyspark.sql import SparkSession\n",
        "\n",
        "spark = SparkSession.builder.master(\"local\").appName(\"FIRST_EXECUTION\").getOrCreate()\n",
        "\n",
        "sc = spark.sparkContext\n",
        "\n",
        "list1 = [\"Hello\", \"World\", \"Students\", \"Hello\", \"Students\", \"World\", \"World\", \"Hello\", \"Hello\"]\n",
        "rdd = sc.parallelize(list1)\n",
        "rdd1 = rdd.map(lambda x: (x,1))\n",
        "rdd2 = rdd1.reduceByKey(lambda x, y: x+y)\n",
        "rdd2.collect()"
      ],
