        "from pyspark.sql import SparkSession\n",
        "\n",
        "spark = SparkSession.builder.appName(\"DataFrame Example\").getOrCreate()\n",
        "\n",
        "# Create DataFrame\n",
        "data = [(\"Alice\", 25), (\"Bob\", 30), (\"Cathy\", 22)]\n",
        "df = spark.createDataFrame(data, [\"Name\", \"Age\"])\n",
        "\n",
        "# Operations\n",
        "df.show()\n",
        "df.filter(df.Age > 23).show()"
